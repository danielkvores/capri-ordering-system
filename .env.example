# Backend
DATABASE_URL=sqlite:///./restaurant_orders.db
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM provider. Use openrouter for the real Milestone 1 flow.
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=replace-with-your-key
OPENROUTER_MODEL=replace-with-an-openrouter-model-id
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=Restaurant Ordering Prototype

# Optional local smoke-test provider with very limited parsing.
# LLM_PROVIDER=mock
