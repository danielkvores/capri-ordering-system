# Backend
DATABASE_URL=sqlite:///./restaurant_orders.db
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM provider. Use cerebras for the fastest free-tier Milestone 1 flow.
LLM_PROVIDER=cerebras

# Cerebras provider.
CEREBRAS_API_KEY=replace-with-your-cerebras-key
CEREBRAS_MODEL=gpt-oss-120b
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# OpenRouter provider fallback.
OPENROUTER_API_KEY=replace-with-your-key
OPENROUTER_MODEL=replace-with-an-openrouter-model-id
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=Restaurant Ordering Prototype

# Optional local smoke-test provider with very limited parsing.
# LLM_PROVIDER=mock
